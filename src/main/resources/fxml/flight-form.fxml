<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.airport.controller.FlightFormController"
      spacing="14" prefWidth="420"
      styleClass="form-root">
    <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>

    <Label text="Данные рейса" styleClass="form-title"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Номер рейса:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="flightNumberField" promptText="SU-1234" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Направление:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="destinationField" promptText="Москва — Донецк" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Дата вылета:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
        <DatePicker fx:id="departureDateField" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Время вылета:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="departureTimeField" promptText="14:30" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Длительность (мин):" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="durationField" promptText="120" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Гейт:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="gateField" promptText="A3" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Статус:" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="form-label"/>
        <ComboBox fx:id="statusCombo" GridPane.rowIndex="6" GridPane.columnIndex="1" prefWidth="220"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Отмена" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button fx:id="saveButton" text="Сохранить" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
